# 数据库（Neon Postgres）
DATABASE_URL=

# ——— 鉴权（多用户）———
# JWT 签名密钥，必填。生成：openssl rand -base64 32
JWT_SECRET=

# 种子用户（可选，默认 demo@job-tracker.local / demo1234）
SEED_USER_EMAIL=
SEED_USER_PASSWORD=

# 插件接口 CORS 来源（可选，默认 *）。插件走 Bearer token 鉴权，放开 * 是安全的；
# 想收紧填 chrome-extension://<你的插件ID>
CORS_ALLOW_ORIGIN=

# ——— 邮件（忘记密码 / 邮箱验证码登录）———
# Resend API key。不填则本地开发把重置链接 / 验证码打到服务端控制台（不真发信）。
RESEND_API_KEY=
# 发件人。需在 Resend 验证过域名；本地测试可用 onboarding@resend.dev。
EMAIL_FROM=OfferGate <onboarding@resend.dev>
# 站点根地址，用于拼重置链接。默认 http://localhost:3000
APP_URL=http://localhost:3000

# ——— 面试复盘模型链（第三步）———
# 注意：用户在设置页自填的 LLM key（存浏览器 localStorage）会随请求覆盖以下 env。
# 下面这些只作为「用户没填时」的服务端兜底，全部可选。
# 按顺序取第一个配置了 key 的 provider 来调，失败自动落到下一个。
# 逗号分隔，可选值：gpt / qwen / deepseek
AI_PROVIDER_ORDER=gpt,qwen,deepseek

# GPT（OpenAI 原生即兼容）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Qwen / 阿里百炼（OpenAI 兼容模式）
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
