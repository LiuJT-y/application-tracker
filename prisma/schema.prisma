// 秋招投递记录工具 —— 数据模型
// 五张核心表覆盖：投递记录、状态时间线、简历版本、面试复盘、日程待办。
// 转化漏斗 / 渠道对比都是对 Application 做聚合查询，不单独建表。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // 运行时：连接池端点(-pooler)
  directUrl = env("DIRECT_URL") // 迁移/db push：直连端点
}

enum ApplicationStatus {
  SAVED // 感兴趣 / 收藏
  APPLIED // 已投递
  OA // 笔试 / OA
  INTERVIEWING // 面试中（具体几面看 currentStage）
  OFFER // 收到 Offer
  REJECTED // 已结束 / 挂
}

enum Channel {
  REFERRAL // 内推
  OFFICIAL // 官网
  HEADHUNTER // 猎头
  SOCIAL // 社交
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ScheduleType {
  INTERVIEW
  OA
  FOLLOWUP
}

// 用户表：JWT+bcrypt 多用户。apiToken 给 Chrome 插件做 Bearer 鉴权用。
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  apiToken     String   @unique @default(cuid()) // 插件用：Authorization: Bearer <apiToken>
  createdAt    DateTime @default(now())

  applications   Application[]
  resumeVersions ResumeVersion[]
  statusEvents   StatusEvent[]
  reviews        InterviewReview[]
  scheduleItems  ScheduleItem[]
}

model Application {
  id           String            @id @default(cuid())
  company      String
  position     String
  city         String?
  salaryRange  String?
  workMode     String? // onsite / remote / hybrid
  channel      Channel           @default(OFFICIAL)
  priority     Priority          @default(MEDIUM)
  status       ApplicationStatus @default(APPLIED)
  currentStage String? // 自由文本：一面 / 二面 / 终面
  jobLink      String?
  jdText       String? // JD 原文，插件抓取后写入
  matchScore   Int? // 插件给出的简历匹配分 0-100
  appliedAt    DateTime?
  order        Int               @default(0) // 看板列内排序

  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id])
  resumeVersionId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  statusEvents  StatusEvent[]
  reviews       InterviewReview[]
  scheduleItems ScheduleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([userId])
}

model StatusEvent {
  id            String            @id @default(cuid())
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  status        ApplicationStatus
  note          String?
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([userId])
}

model ResumeVersion {
  id      String  @id @default(cuid())
  name    String // "通用技术 v3.2"
  version String?
  fileUrl String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  applications Application[]
  createdAt    DateTime      @default(now())

  @@index([userId])
}

model InterviewReview {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  stage         String? // 轮次：一面/二面/HR面/终面（取自 INTERVIEW_STAGES）
  format        String? // 形式：视频/电话/现场/AI 面（取自 INTERVIEW_FORMATS）
  scores        Json // 8 维度评分 { overall, expression, technical, ... }
  strengths     String? // 优势
  weaknesses    String? // 待改进
  improvement   String? // 改进计划
  rawTranscript String? // 表单字段拼成的复盘原文
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([userId])
}

model ScheduleItem {
  id            String       @id @default(cuid())
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  type          ScheduleType
  title         String
  dueAt         DateTime
  done          Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([applicationId])
  @@index([userId])
}
