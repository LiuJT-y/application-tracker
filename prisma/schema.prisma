// 秋招投递记录工具 —— 数据模型
// 五张核心表覆盖：投递记录、状态时间线、简历版本、面试复盘、日程待办。
// 转化漏斗 / 渠道对比都是对 Application 做聚合查询，不单独建表。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // 运行时：连接池端点(-pooler)
  directUrl = env("DIRECT_URL") // 迁移/db push：直连端点
}

enum ApplicationStatus {
  SAVED // 感兴趣 / 收藏
  APPLIED // 已投递
  OA // 笔试 / OA
  INTERVIEWING // 面试中（具体几面看 currentStage）
  OFFER // 收到 Offer
  REJECTED // 已结束 / 挂
}

enum Channel {
  REFERRAL // 内推
  OFFICIAL // 官网
  HEADHUNTER // 猎头
  SOCIAL // 社交
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ScheduleType {
  INTERVIEW
  OA
  FOLLOWUP
}

// 简历素材库条目类型：把简历拆成可复用的条目，后续组合成不同版本。
enum ResumeItemType {
  PROFILE // 个人简介 / 求职意向
  EXPERIENCE // 工作 / 实习经历
  PROJECT // 项目经历
  EDUCATION // 教育经历
  SKILL // 技能
  OTHER
}

// 简历版本来源：COMPOSED = 由素材库条目组合（Part 2）；UPLOADED = 上传的 PDF（Part 3 留用）。
enum ResumeVersionSource {
  COMPOSED
  UPLOADED
}

// 用户表：JWT+bcrypt 多用户。apiToken 给 Chrome 插件做 Bearer 鉴权用。
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  apiToken     String   @unique @default(cuid()) // 插件用：Authorization: Bearer <apiToken>
  createdAt    DateTime @default(now())

  applications       Application[]
  resumeVersions     ResumeVersion[]
  resumeItems        ResumeItem[]
  resumeVersionItems ResumeVersionItem[]
  resumeFiles        ResumeFile[]
  resumeProfile      ResumeProfile?
  statusEvents       StatusEvent[]
  reviews            InterviewReview[]
  scheduleItems      ScheduleItem[]
}

// 个人信息：每个用户全局唯一一条（userId 唯一），独立于 ResumeItem 总表管理。
// 生成简历时作为抬头（姓名/联系方式/一句话意向）。
model ResumeProfile {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  name      String?
  email     String?
  phone     String?
  location  String?
  github    String? // GitHub 主页
  linkedin  String? // 领英主页
  updatedAt DateTime @updatedAt
}

model Application {
  id           String            @id @default(cuid())
  company      String
  position     String
  city         String?
  salaryRange  String?
  workMode     String? // onsite / remote / hybrid
  channel      Channel           @default(OFFICIAL)
  priority     Priority          @default(MEDIUM)
  status       ApplicationStatus @default(APPLIED)
  currentStage String? // 自由文本：一面 / 二面 / 终面
  jobLink      String?
  jdText       String? // JD 原文，插件抓取后写入
  matchScore   Int? // 插件给出的简历匹配分 0-100
  appliedAt    DateTime?
  order        Int               @default(0) // 看板列内排序

  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id])
  resumeVersionId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  statusEvents  StatusEvent[]
  reviews       InterviewReview[]
  scheduleItems ScheduleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([userId])
}

model StatusEvent {
  id            String            @id @default(cuid())
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  status        ApplicationStatus
  note          String?
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([userId])
}

model ResumeVersion {
  id        String              @id @default(cuid())
  name      String // "通用技术 v3.2"
  version   String?
  fileUrl   String? // Part 3 上传 PDF 用
  isDefault Boolean             @default(false) // 看板新建投递时预填的默认版本（每用户至多一个）
  note      String? // 备注：这版主打什么
  source    ResumeVersionSource @default(COMPOSED) // 组合 / 上传

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  applications Application[]
  items        ResumeVersionItem[]
  file         ResumeFile? // 一对一：该版本上传的 PDF（Part 3a），有就当 source=UPLOADED
  createdAt    DateTime            @default(now())

  @@index([userId])
}

// 简历 PDF 字节：单独一张表存大字节，避免污染 ResumeVersion 的常规查询。
// data 用 Prisma Bytes（SQLite 与 Postgres 都支持），只有下载接口才 SELECT data。
model ResumeFile {
  id        String        @id @default(cuid())
  version   ResumeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId String        @unique // 一个版本最多一个 PDF
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  data      Bytes // PDF 原始字节
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime      @default(now())

  @@index([userId])
}

// 简历版本 ↔ 素材条目的有序关联表（Part 2 版本组合）。
model ResumeVersionItem {
  id        String   @id @default(cuid())
  version   ResumeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId String
  item      ResumeItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  order     Int      @default(0) // 该条目在这个版本里的排序
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([versionId])
  @@index([userId])
}

model InterviewReview {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  stage         String? // 轮次：一面/二面/HR面/终面（取自 INTERVIEW_STAGES）
  format        String? // 形式：视频/电话/现场/AI 面（取自 INTERVIEW_FORMATS）
  scores        Json // 8 维度评分 { overall, expression, technical, ... }
  strengths     String? // 优势
  weaknesses    String? // 待改进
  improvement   String? // 改进计划
  rawTranscript String? // 表单字段拼成的复盘原文
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([userId])
}

model ScheduleItem {
  id            String       @id @default(cuid())
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  type          ScheduleType
  title         String
  dueAt         DateTime
  done          Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([applicationId])
  @@index([userId])
}

// 简历素材库条目：简历管理的地基。把简历拆成可复用的条目（项目/经历/教育/技能），
// 后续（Part 2）再用这些条目组合成不同的简历版本。日期用字符串存（"2024.09" / "至今"）。
model ResumeItem {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        ResumeItemType @default(EXPERIENCE)
  title       String // 标题：项目名 / 公司名 / 学校
  org         String? // 机构 / 公司 / 学校
  location    String?
  role        String? // 项目/经历用：角色，如「独立研究 / 后端开发」
  degree      String? // 教育用：学位/专业，如「计算机科学硕士」
  startDate   String? // "2024.09"
  endDate     String? // "2025.06" / "至今"
  description String?        @db.Text // 旧的「正文/要点」一段文本；已迁移进 bullets，保留过渡用
  bullets     String[]       @default([]) // 结构化要点：一条一个（对应简历里每个 ◦ 列表项）
  tags        String[]       @default([])
  link        String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  versionItems ResumeVersionItem[]

  @@index([userId])
  @@index([userId, type])
}
